│   ├── types/
│   │   └── index.ts               # TypeScript interfaces
│   ├── utils/
│   │   └── spatial.ts             # Helper Turf.js
│   ├── App.tsx
│   ├── main.tsx
│   └── index.css
├── .env                           # VITE_GOOGLE_MAPS_API_KEY
├── index.html
├── vite.config.ts
└── package.json
```

